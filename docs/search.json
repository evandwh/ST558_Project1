59 p.m.\",\n  \"11:00 p.m. to 11:29 p.m.\",\n  \"11:30 p.m. to 11:59 p.m.\",\n  \"0\"\n)\n\nnames(jwdp_time_lookup) &lt;-c(1:150,0)\njwdp_times &lt;- sapply(jwdp_time_lookup, \n                     interval_midpoint)\n\n\nhead(jwap_times)\n\n   1    2    3    4    5    6 \n 120  420  720 1020 1320 1620 \n\n\n\nhead(jwdp_times)\n\n   1    2    3    4    5    6 \n 870 2670 4470 6270 8070 9870 \n\n\n\ncensus_rawdata_to_tibble &lt;- function(raw_data) {\n  numeric_cols &lt;- c(\"AGEP\", \"GASP\", \"GRPIP\", \"JWMNP\", \"PWGTP\")\n  parsed &lt;- fromJSON(rawToChar(raw_data$content))\n  data &lt;- as_tibble(parsed[-1, ])\n  colnames(data) &lt;- parsed[1, ]\n  if (\"JWAP\" %in% colnames(data)) {\n    data &lt;- data |&gt; \n      mutate(\n        JWAP = jwap_time_lookup[JWAP]\n      )\n  }\n  if (\"JWDP\" %in% colnames(data)) {\n    data &lt;- data |&gt; \n      mutate(\n        JWDP = jwdp_time_lookup[JWDP]\n      )\n  }\n  data &lt;- data |&gt;\n    mutate(across(any_of(numeric_cols), as.numeric)) |&gt;\n    mutate(\n      JWAP = na_if(as.character(JWAP), \"0\"),\n      JWDP = na_if(as.character(JWDP), \"0\"),\n      JWAP = parse_hm(JWAP),\n      JWDP = parse_hm(JWDP)\n    )\n  if (\"SEX\" %in% colnames(data)) {\n      data$SEX = factor(data$SEX, \n                        levels = c(1, 2),\n                        labels = c(\"Male\", \"Female\"))\n        }\n  if (\"FER\" %in% colnames(data)) {\n      data$FER = factor(data$FER, \n                        levels = c(0, 1, 2),\n                        labels = c(\"N/A (less than 15 years/greater than 50 years/ male)\",\n                                   \"Yes\",\n                                   \"No\"))  \n      }\n  if (\"HHL\" %in% colnames(data)) {\n      data$HHL = factor(data$HHL, \n                           levels = c(0, 1, 2, 3, 4, 5),\n                           labels = c(\"N/A (GQ/vacant)\",\n                                      \"English Only\",\n                                      \"Spanish\",\n                                      \"Other Indo-European languages\",\n                                      \"Asian and Pacific Island languages\",\n                                      \"Other Language\"))\n        }\n  if (\"SCL\" %in% colnames(data)) {      \n      data$SCL = factor(data$SCL, \n                           levels = c(0,1,2,3),\n                           labels = c(\"N/A (less than 3 years old)\",\n                                      \"No, has not attended in the last 3 months\",\n                                      \"Yes, public school or public college\",\n                                      \"Yes, private school or college or home school\"))\n        }\n  if (\"SCHL\" %in% colnames(data)) {\n      data$SCHL = factor(data$SCHL, \n                            levels = c(0:24),\n                            labels = c(\"N/A (less than 3 years old)\",\n                                       \"No schooling completed\",\n                                       \"Nursery school, preschool\",\n                                       \"Kindergarten\",\n                                       \"Grade 1\",\n                                       \"Grade 2\",\n                                       \"Grade 3\",\n                                       \"Grade 4\",\n                                       \"Grade 5\",\n                                       \"Grade 6\",\n                                       \"Grade 7\",\n                                       \"Grade 8\",\n                                       \"Grade 9\",\n                                       \"Grade 10\",\n                                       \"Grade 11\",\n                                       \"12th grade - no diploma\",\n                                       \"Regular high school diploma\",\n                                       \"GED or alternative credential\",\n                                       \"Some college, but less than 1 year\",\n                                       \"1 or more years of college credit, no degree\",\n                                       \"Associate's degree\",\n                                       \"Bachelor's degree\",\n                                       \"Master's degree\",\n                                       \"Professional degree beyond a bachelor's degree\",\n                                       \"Doctorate degree\")\n                       )\n  }\n  class(data) &lt;- c(\"census\", class(data))\n  data\n}\n\n\nhelp_codes &lt;- function(geo, geo_name) {\n  state_fips &lt;- c(\n    AL = \"01\", AK = \"02\", AZ = \"04\", AR = \"05\", CA = \"06\",\n    CO = \"08\", CT = \"09\", DE = \"10\", DC = \"11\", FL = \"12\",\n    GA = \"13\", HI = \"15\", ID = \"16\", IL = \"17\", IN = \"18\",\n    IA = \"19\", KS = \"20\", KY = \"21\", LA = \"22\", ME = \"23\",\n    MD = \"24\", MA = \"25\", MI = \"26\", MN = \"27\", MS = \"28\",\n    MO = \"29\", MT = \"30\", NE = \"31\", NV = \"32\", NH = \"33\",\n    NJ = \"34\", NM = \"35\", NY = \"36\", NC = \"37\", ND = \"38\",\n    OH = \"39\", OK = \"40\", OR = \"41\", PA = \"42\", RI = \"44\",\n    SC = \"45\", SD = \"46\", TN = \"47\", TX = \"48\", UT = \"49\",\n    VT = \"50\", VA = \"51\", WA = \"53\", WV = \"54\", WI = \"55\",\n    WY = \"56\"\n  )\n  region_codes &lt;- c(\n    Northeast = \"1\",\n    Midwest   = \"2\",\n    South     = \"3\",\n    West      = \"4\"\n  )\n  division_codes &lt;- c(\n    New_England        = \"1\",\n    Middle_Atlantic    = \"2\",\n    East_North_Central = \"3\",\n    West_North_Central = \"4\",\n    South_Atlantic     = \"5\",\n    East_South_Central = \"6\",\n    West_South_Central = \"7\",\n    Mountain           = \"8\",\n    Pacific            = \"9\"\n  )\n  if (geo == \"STATE\") {\n    if ((geo_name %in% names(state_fips))) {\n      code &lt;- state_fips[[geo_name]]\n    } else if (geo_name %in% state_fips) {\n      code &lt;- geo_name\n    } else {\n      stop(\"State code not found\")\n    }\n  } else if (geo == \"REGION\") {\n    if (geo_name %in% names(region_codes)) {\n      code &lt;- region_codes[[geo_name]]\n    } else if (geo_name %in% region_codes) {\n      code &lt;- geo_name\n    } else {\n      stop(\"Region code not found\")\n    }\n  } else if (geo == \"DIVISION\") {\n    if (geo_name %in% names(division_codes)) {\n      code &lt;- division_codes[[geo_name]]\n    } else if (geo_name %in% division_codes) {\n      code &lt;- geo_name\n    } else {\n      stop(\"Division code not found\")\n    }\n  } else {\n    stop(\"Invalid input. Incorrect geograph type.\")\n  }\n  code\n}\n\nhelp_codes(\"STATE\", \"NC\")\n\n[1] \"37\"\n\n\nNow, these should not be character columns. We will fix that later if/when needed once we get our function running! Let’s build that function.\n\nsingle_year_rawdata &lt;- function(year = 2022, \n                       num_vars = c(\"AGEP\", \"PWGTP\"),  #AGEP and PWGTP by default\n                       cat_vars = c(\"SEX\"), #SEX by default\n                       geo = \"STATE\",       #State by default\n                       geo_name = \"NC\",\n                       key = \"70c77fa9cc244f5a9fb3c46ed731835d132c0670\") {\n  num_vars &lt;- toupper(num_vars)\n  cat_vars &lt;- toupper(cat_vars)\n  geo &lt;- toupper(geo)\n  if (year &gt; 2022 || year &lt; 2010) {\n    stop(\"Year must be between 2010 and 2022, inclusive.\")\n  }\n  if (!(\"PWGTP\" %in% num_vars)) {\n    num_vars &lt;- c(num_vars, \"PWGTP\")  #Always want PWGTP\n  }\n  if (length(num_vars) &lt;= 1) {\n    stop(\"Please provide more than one numerical variable.\")\n  }\n  for (k in num_vars) {\n    if (!(k %in% c(\"AGEP\", \"GASP\", \"GRPIP\", \"JWAP\", \"JWDP\", \"JWMNP\", \"PWGTP\"))) {\n      stop(\"Please choose only valid options for num_vars.\")\n    }\n  }\n  for (k in cat_vars) {\n    if (!(k %in% c(\"FER\", \"HHL\", \"SCH\", \"SCHL\", \"SEX\"))) {\n      stop(\"Please choose only valid options for cat_vars.\")\n    }\n  }\n  if (length(cat_vars) == 0) {  #Must have at least one categorical variable.\n    stop(\"Must have at least one categorical variable.\")\n  }\n  if (!(is.null(geo))) {\n    if (!(toupper(geo) %in% c(\"REGION\", \"DIVISION\", \"STATE\"))) {\n      stop(\"Incorrect Geography provided\")\n    }\n    geo_string &lt;- paste0(\"&for=\",geo)\n  } else {\n    geo_string &lt;- \"\"\n  }\n  if ((geo_string == \"\") && (!(is.null(geo_name)))) {\n    stop(\"Cannot give a location without a specificed geography type\")\n  }\n  if (geo_name == \"ALL\") {\n    code &lt;- \"*\"\n  }\n  else {\n    code &lt;- help_codes(geo, geo_name)\n  }\n  geo_string &lt;- paste0(geo_string,\":\",code)\n  num_string &lt;- paste(num_vars, collapse = \",\")\n  cat_string &lt;- paste(cat_vars, collapse = \",\")\n  url &lt;- paste0(\"https://api.census.gov/data/\",\n                year,\n                \"/acs/acs1/pums?get=\",\n                cat_string,\n                \",\", #cat_var and num_var always have at least one element\n                num_string,\n                geo_string,\n                \"&key=\",\n                key)\n  print(url)\n  results &lt;- GET(url)\n}\n\n\ntrial_dat &lt;- single_year_rawdata(2019, num_vars = c(\"JWAP\", \"JWDP\"), cat_vars = c(\"SEX\", \"SCHL\"))\n\n[1] \"https://api.census.gov/data/2019/acs/acs1/pums?get=SEX,SCHL,JWAP,JWDP,PWGTP&for=STATE:37&key=70c77fa9cc244f5a9fb3c46ed731835d132c0670\"\n\ntrial_data &lt;- census_rawdata_to_tibble(trial_dat)\n\nstr(trial_data)\n\ncensus [103,516 × 6] (S3: census/tbl_df/tbl/data.frame)\n $ SEX  : Factor w/ 2 levels \"Male\",\"Female\": 1 1 1 1 1 1 1 1 2 2 ...\n $ SCHL : Factor w/ 25 levels \"N/A (less than 3 years old)\",..: 15 17 17 10 2 20 12 20 20 21 ...\n $ JWAP : 'hms' num [1:103516] NA NA NA NA ...\n  ..- attr(*, \"units\")= chr \"secs\"\n $ JWDP : 'hms' num [1:103516] NA NA NA NA ...\n  ..- attr(*, \"units\")= chr \"secs\"\n $ PWGTP: num [1:103516] 70 70 16 80 7 52 82 31 72 62 ...\n $ state: chr [1:103516] \"37\" \"37\" \"37\" \"37\" ...\n\nhead(trial_data, 50)\n\n# A tibble: 50 × 6\n   SEX    SCHL                                         JWAP   JWDP   PWGTP state\n   &lt;fct&gt;  &lt;fct&gt;                                        &lt;time&gt; &lt;time&gt; &lt;dbl&gt; &lt;chr&gt;\n 1 Male   Grade 11                                        NA     NA     70 37   \n 2 Male   Regular high school diploma                     NA     NA     70 37   \n 3 Male   Regular high school diploma                     NA     NA     16 37   \n 4 Male   Grade 6                                         NA     NA     80 37   \n 5 Male   No schooling completed                          NA     NA      7 37   \n 6 Male   1 or more years of college credit, no degree    NA     NA     52 37   \n 7 Male   Grade 8                                         NA     NA     82 37   \n 8 Male   1 or more years of college credit, no degree    NA     NA     31 37   \n 9 Female 1 or more years of college credit, no degree    NA     NA     72 37   \n10 Female Associate's degree                              NA     NA     62 37   \n# ℹ 40 more rows\n\n\n\nmultiple_years_data &lt;- function(years,\n                                num_vars = c(\"AGEP\", \"PWGTP\"),  #AGEP and PWGTP by default\n                                cat_vars = c(\"SEX\"), #SEX by default\n                                geo = \"STATE\",       #State by default\n                                geo_name = \"NC\",\n                                key = \"70c77fa9cc244f5a9fb3c46ed731835d132c0670\") {\n  df &lt;- NULL\n  years &lt;- years[years != 2020]\n  for (year in years) {\n    year_data &lt;- census_rawdata_to_tibble(\n                    single_year_rawdata(year,\n                                        num_vars,\n                                        cat_vars,\n                                        geo,\n                                        geo_name,\n                                        key)\n    )\n    year_data$year = year\n    if (!(exists(\"df\"))) {\n      df &lt;-  year_data\n    } else {\n      df &lt;-  bind_rows(df, year_data)\n    }\n  }\n  df\n}\n\n\ntrial_multiyear_data &lt;- multiple_years_data(years = c(2019, 2021), num_vars = c(\"AGEP\", \"GASP\", \"GRPIP\", \"JWAP\", \"JWDP\", \"JWMNP\", \"PWGTP\"), cat_vars = c(\"FER\", \"HHL\", \"SCH\", \"SCHL\", \"SEX\"))\n\n[1] \"https://api.census.gov/data/2019/acs/acs1/pums?get=FER,HHL,SCH,SCHL,SEX,AGEP,GASP,GRPIP,JWAP,JWDP,JWMNP,PWGTP&for=STATE:37&key=70c77fa9cc244f5a9fb3c46ed731835d132c0670\"\n[1] \"https://api.census.gov/data/2021/acs/acs1/pums?get=FER,HHL,SCH,SCHL,SEX,AGEP,GASP,GRPIP,JWAP,JWDP,JWMNP,PWGTP&for=STATE:37&key=70c77fa9cc244f5a9fb3c46ed731835d132c0670\"\n\nhead(trial_multiyear_data, 10)\n\n# A tibble: 10 × 14\n   FER   HHL   SCH   SCHL  SEX    AGEP  GASP GRPIP JWAP  JWDP  JWMNP PWGTP state\n   &lt;fct&gt; &lt;fct&gt; &lt;chr&gt; &lt;fct&gt; &lt;fct&gt; &lt;dbl&gt; &lt;dbl&gt; &lt;dbl&gt; &lt;tim&gt; &lt;tim&gt; &lt;dbl&gt; &lt;dbl&gt; &lt;chr&gt;\n 1 N/A … N/A … 1     Grad… Male     52     3     0    NA    NA     0    70 37   \n 2 N/A … N/A … 1     Regu… Male     50     3     0    NA    NA     0    70 37   \n 3 N/A … N/A … 1     Regu… Male     28     3     0    NA    NA     0    16 37   \n 4 N/A … N/A … 1     Grad… Male     49     3     0    NA    NA     0    80 37   \n 5 N/A … N/A … 2     No s… Male      3     3     0    NA    NA     0     7 37   \n 6 N/A … N/A … 1     1 or… Male     30     3     0    NA    NA     0    52 37   \n 7 N/A … N/A … 1     Grad… Male     67     3     0    NA    NA     0    82 37   \n 8 N/A … N/A … 3     1 or… Male     19     3     0    NA    NA     0    31 37   \n 9 No    N/A … 3     1 or… Fema…    22     3     0    NA    NA     0    72 37   \n10 N/A … N/A … 1     Asso… Fema…    67     3     0    NA    NA     0    62 37   \n# ℹ 1 more variable: year &lt;dbl&gt;\n\nclass(trial_multiyear_data)\n\n[1] \"census\"     \"tbl_df\"     \"tbl\"        \"data.frame\"\n\n\n\nweighted_mean &lt;- function(col, weight) {\n  sum(col * weight, na.rm = TRUE) / sum(weight, na.rm = TRUE)\n}\n\nweighted_sd &lt;- function(col, weight) {\n  mu &lt;- weighted_mean(col, weight)\n  sqrt(\n    sum(col^2 * weight, na.rm = TRUE) / sum(weight, na.rm = TRUE) - mu^2\n  )\n}\n\n\nsummary.census &lt;- function(data, num_vars = NULL, cat_vars = NULL) {\n  if (is.null(num_vars)) {\n    num_vars &lt;- data |&gt; \n      select(where(is.numeric)) |&gt; \n      names()\n    num_vars &lt;- setdiff(num_vars, c(\"year\",\"PWGTP\"))\n  }\n  if (is.null(cat_vars)) {\n    cat_vars &lt;- data |&gt;\n      select(where(is.factor)) |&gt;\n      names()\n  }\n  numerical_summary &lt;- data |&gt; \n    summarise(\n      across(\n        all_of(num_vars), \n        list(\n          mean = ~ weighted_mean(.x, PWGTP),\n          sd   = ~ weighted_sd(.x, PWGTP)\n          ),\n        .names = \"{.col}_{.fn}\") |&gt;\n    pivot_longer(\n      everything(),\n      names_to = c(\"variable\", \"statistic\"),\n      names_sep = \"_\",\n      values_to = \"value\"\n    )\n    )\n  \n  categorical_summary &lt;- data |&gt;\n    pivot_longer(\n      cols = all_of(cat_vars),\n      names_to = \"variable\",\n      values_to = \"level\"\n    ) |&gt;\n    count(variable, level)\n  \n  full_summary &lt;- list(\n    \"Numeric_Summary\" = numerical_summary, \n    \"Categorical_Summary\" = categorical_summary)\n  full_summary\n}\n\n\nproject_summary &lt;- summary(trial_multiyear_data)\n\nWarning: Returning more (or less) than 1 row per `summarise()` group was deprecated in\ndplyr 1.1.0.\nℹ Please use `reframe()` instead.\nℹ When switching from `summarise()` to `reframe()`, remember that `reframe()`\n  always returns an ungrouped data frame and adjust accordingly.\n\nproject_summary$Categorical_Summary\n\n# A tibble: 36 × 3\n   variable level                                                     n\n   &lt;chr&gt;    &lt;fct&gt;                                                 &lt;int&gt;\n 1 FER      N/A (less than 15 years/greater than 50 years/ male) 163721\n 2 FER      Yes                                                    2140\n 3 FER      No                                                    41992\n 4 HHL      N/A (GQ/vacant)                                       11477\n 5 HHL      English Only                                         168715\n 6 HHL      Spanish                                               15884\n 7 HHL      Other Indo-European languages                          5643\n 8 HHL      Asian and Pacific Island languages                     4592\n 9 HHL      Other Language                                         1542\n10 SCHL     N/A (less than 3 years old)                            5520\n# ℹ 26 more rows\n\n\n\nplot.census &lt;- function(data, num_var, cat_var) {\n  ggplot(\n    data,\n    aes(\n      x = get(cat_var),\n      y = get(num_var),\n      weight = PWGTP\n    )\n  ) +\n    geom_boxplot() +\n    labs(\n      x = cat_var,\n      y = num_var,\n      title = paste(num_var, \"by\", cat_var)\n  ) + \n    theme(\n      axis.text.x = element_text(angle = 45, hjust = 1)\n  )\n}\n\nplot(trial_multiyear_data, num_var = \"AGEP\", cat_var = \"HHL\")"
