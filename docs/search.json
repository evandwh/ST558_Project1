    "text": "Just getting started.\n\nlibrary(httr)\nlibrary(jsonlite)\nlibrary(curl)\nlibrary(dplyr)\nlibrary(stringr)\nlibrary(lubridate)\nlibrary(hms)\nlibrary(tidyr)\nlibrary(ggplot2)\nlibrary(quantreg)\n\n\nkey &lt;- \"70c77fa9cc244f5a9fb3c46ed731835d132c0670\"\n\nLet’s do a quick test!\n\nurl &lt;- paste0(\"https://api.census.gov/data/2022/acs/acs1/pums?get=SEX,PWGTP,MAR&SCHL=24&key=\", key)\n\nresponse &lt;- GET(url, timeout(120))\nparsed &lt;- fromJSON(rawToChar(response$content))\ndata &lt;- as_tibble(parsed[-1, ])\ncolnames(data) &lt;- parsed[1, ]\n\nstr(data)\n\ntibble [44,079 × 4] (S3: tbl_df/tbl/data.frame)\n $ SEX  : chr [1:44079] \"2\" \"2\" \"1\" \"1\" ...\n $ PWGTP: chr [1:44079] \"6\" \"23\" \"23\" \"80\" ...\n $ MAR  : chr [1:44079] \"5\" \"2\" \"3\" \"5\" ...\n $ SCHL : chr [1:44079] \"24\" \"24\" \"24\" \"24\" ...\n\n\n\ninterval_midpoint &lt;- function(time_string) {\n  \n  if (time_string == \"0\") {\n    return(hms::as_hms(NA))\n  }\n\n  pieces &lt;- str_split(time_string, \" to \", simplify = TRUE)\n\n  start &lt;- str_trim(pieces[1])\n  end &lt;- str_trim(pieces[2])\n  \n  start &lt;- str_replace_all(start, \" a.m.\", \" AM\")\n  start &lt;- str_replace_all(start, \" p.m.\", \" PM\")\n  \n  end &lt;- str_replace_all(end, \" a.m.\", \" AM\")\n  end &lt;- str_replace_all(end, \" p.m.\", \" PM\")\n  \n  start_time &lt;- parse_date_time(start, orders = \"I:M p\")\n  end_time &lt;- parse_date_time(end, orders = \"I:M p\")\n\n  midpoint &lt;- start_time + (end_time - start_time) / 2\n  hms::as_hms(midpoint)\n}\n\ninterval_midpoint(\"12:00 a.m. to 12:04 a.m.\")\n\n00:02:00\n\n\n\njwap_time_lookup &lt;- c(\n    \"12:00 a.m. to 12:04 a.m.\",\n    \"12:05 a.m. to 12:09 a.m.\",\n    \"12:10 a.m. to 12:14 a.m.\",\n    \"12:15 a.m. to 12:19 a.m.\",\n    \"12:20 a.m. to 12:24 a.m.\",\n    \"12:25 a.m. to 12:29 a.m.\",\n    \"12:30 a.m. to 12:39 a.m.\",\n    \"12:40 a.m. to 12:44 a.m.\",\n    \"12:45 a.m. to 12:49 a.m.\",\n    \"12:50 a.m. to 12:59 a.m.\"